<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- "All files access": raw file-path access to /storage/emulated/0/JCode (workspace root and
         proot bind mounts). Legacy storage permissions stopped working at targetSdk 30+; granted
         via the system settings toggle, checked with Environment.isExternalStorageManager(). -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- In-app updater: install a downloaded release APK from Settings → About → Update. The system
         still shows its install confirmation / Play Protect scan for an unrecognized build; a
         same-signature self-update can be silent. Gated at runtime by canRequestPackageInstalls(). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Package visibility (targetSdk 30+): the "Open web previews in" picker enumerates
         installed browsers via queryIntentActivities(ACTION_VIEW http/https). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:networkSecurityConfig="@xml/network_security_config"
        android:allowBackup="false"
        android:icon="${appIcon}"
        android:roundIcon="${appIconRound}"
        android:label="${appLabel}"
        android:supportsRtl="true"
        android:theme="@style/Theme.JCode.Starting">

        <!-- hardwareAccelerated=false so the user's Settings toggle governs it: MainActivity enables
             acceleration via FLAG_HARDWARE_ACCELERATED (window level can only ENABLE, never disable,
             so the manifest default must be off for an opt-out to be possible). Default pref is ON. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:hardwareAccelerated="false"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboard|keyboardHidden|navigation|uiMode|density|fontScale|locale|layoutDirection"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".BackendService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="interactive_terminal_and_build_runner" />
        </service>

        <!-- Exposes the app-private ext4 projects tree to the system Files app / SAF pickers as a
             browsable "JCode Projects" root (files never leave ext4). Guarded by MANAGE_DOCUMENTS,
             which only DocumentsUI holds; authority is per-variant so debug/beta/release coexist. -->
        <provider
            android:name=".provider.ProjectsDocumentsProvider"
            android:authorities="${applicationId}.documents"
            android:exported="true"
            android:grantUriPermissions="true"
            android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>

        <!-- Receives PackageInstaller session status for the in-app updater (see AppUpdateInstaller).
             Not exported: it only handles the PendingIntent this app hands to its own commit(). -->
        <receiver
            android:name=".AppInstallReceiver"
            android:exported="false" />

    </application>

</manifest>
